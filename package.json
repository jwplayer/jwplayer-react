{
  "name": "@jwplayer/jwplayer-react",
  "version": "2.0.0",
  "description": "A react component that creates an instance of JW Player",
  "license": "ISC",
  "author": "Zachary Haigh",
  "homepage": "https://github.com/jwplayer/jwplayer-react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jwplayer/jwplayer-react.git"
  },
  "bugs": {
    "url": "https://github.com/jwplayer/jwplayer-react/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./lib/jwplayer-react.js",
  "types": "./lib/jwplayer-react.d.ts",
  "scripts": {
    "build": "webpack && npm run build:types && npm run badges:build:passing || (npm run badges:build:failing && exit 1)",
    "build:types": "node -e \"require('fs').copyFileSync('./src/jwplayer-react.d.ts', './lib/jwplayer-react.d.ts')\"",
    "ci": "npm-run-all -p build test lint test:types badges:license",
    "demo": "webpack --config webpack.demo.js",
    "lint": "eslint ./src/**/* --fix",
    "prepublishOnly": "npm run build",
    "test": "jest --coverage && npm run badges:coverage && npm run badges:test:passing || (npm run badges:test:failing && exit 1)",
    "test:compat": "node ./test/compat/run.js",
    "test:types": "tsc -p ./test/types",
    "badges:build:passing": "badge build passing :brightgreen > ./badges/build.svg",
    "badges:build:failing": "badge build failing :red > ./badges/build.svg",
    "badges:coverage": "node ./badges/util/coverage.js",
    "badges:test:passing": "badge tests passing :brightgreen > ./badges/test.svg",
    "badges:test:failing": "badge tests failing :red > ./badges/test.svg",
    "badges:license": "badge license ISC :brightgreen > ./badges/license.svg"
  },
  "peerDependencies": {
    "react": "^17.0.2 || ^18.0.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.0",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.2.0",
    "badge-maker": "^3.3.1",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^26.0.0",
    "mri": "^1.2.0",
    "npm-run-all": "^4.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^5.1.0"
  },
  "keywords": [
    "jw",
    "jwplayer",
    "player",
    "react"
  ],
  "jest": {
    "collectCoverageFrom": [
      "src/**/*",
      "!src/**/*.d.ts"
    ],
    "coverageReporters": [
      "json-summary"
    ]
  }
}
